{
  "$schema": "https://opencode.ai/config.json",
  "model": "omlx/Qwen3.5-35B-A3B-8bit",
  "small_model": "omlx/Qwen3.5-35B-A3B-8bit",
  "disabled_providers": [
    "opencode"
  ],
  "snapshot": false,
  "provider": {
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX (local MLX)",
      "options": {
        "baseURL": "http://host.docker.internal:8000/v1",
        "apiKey": "{env:OMLX_API_KEY}"
      },
      "models": {
        "gemma-4-26b-a4b-it-4bit": {
          "name": "Gemma 4 26B A4B (MLX)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "gemma-4-31b-it-4bit": {
          "name": "Gemma 4 31B (MLX)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "gpt-oss-20b-MXFP4-Q8": {
          "name": "GPT-OSS 20B (MLX)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "gpt-oss-120b-MXFP4-Q8": {
          "name": "GPT-OSS 120B (MLX)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "Qwen3.5-35B-A3B-8bit": {
          "name": "Qwen 3.5 35B A3B MoE 8-bit (MLX)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "Qwen3-Coder-30B-A3B-Instruct-4bit": {
          "name": "Qwen 3 Coder 30B A3B MoE 4-bit (MLX)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "gemma-4-31b-it-8bit": {
          "name": "Gemma 4 31B IT 8-bit (MLX)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "gemma-4-31b-8bit": {
          "name": "Gemma 4 31B 8-bit (MLX)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    },
    "openai": {
      "name": "OpenAI",
      "models": {
        "gpt-4o": {
          "name": "GPT-4o",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "gpt-4o-mini": {
          "name": "GPT-4o Mini",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "o3-mini": {
          "name": "o3-mini",
          "limit": {
            "context": 200000,
            "output": 100000
          }
        }
      }
    },
    "google": {
      "npm": "@ai-sdk/google",
      "name": "Google Gemini",
      "models": {
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash",
          "limit": {
            "context": 1048576,
            "output": 65536
          }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
          "limit": {
            "context": 1048576,
            "output": 65536
          }
        }
      }
    },
    "anthropic": {
      "name": "Anthropic",
      "models": {
        "claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5",
          "limit": {
            "context": 200000,
            "output": 16384
          }
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        }
      }
    },
    "ollama-cloud": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Cloud (Qwen 397B)",
      "options": {
        "baseURL": "https://ollama.com/v1",
        "apiKey": "{env:OLLAMA_API_KEY}"
      },
      "models": {
        "qwen3.5:397b": {
          "name": "Qwen 3.5 397B (Ollama Cloud)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    }
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "codesearch": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "question": "allow",
    "write": "allow",
    "bash": {
      "*": "allow",
      "rm -rf /workspace/repos/*": "deny",
      "rm -rf /home/*": "deny"
    },
    "edit": {
      "*.env": "deny",
      "*.env.*": "deny",
      "*": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.git/**",
      "**/vendor/**",
      "**/*.log",
      "**/coverage/**"
    ]
  },
  "agent": {
    "pai-boss": {
      "model": "omlx/Qwen3.5-35B-A3B-8bit",
      "maxSteps": 50
    },
    "pai-architect": {
      "model": "omlx/Qwen3.5-35B-A3B-8bit",
      "maxSteps": 30
    },
    "pai-engineer": {
      "model": "omlx/Qwen3.5-35B-A3B-8bit",
      "maxSteps": 40
    },
    "pai-designer": {
      "model": "omlx/Qwen3.5-35B-A3B-8bit",
      "maxSteps": 30
    },
    "pai-qa": {
      "model": "omlx/Qwen3.5-35B-A3B-8bit",
      "maxSteps": 30
    },
    "pai-pentester": {
      "model": "omlx/Qwen3.5-35B-A3B-8bit",
      "maxSteps": 20
    },
    "pai-artist": {
      "model": "omlx/Qwen3.5-35B-A3B-8bit",
      "maxSteps": 20
    },
    "pai-researcher": {
      "model": "omlx/Qwen3.5-35B-A3B-8bit",
      "maxSteps": 25
    },
    "pai-sre": {
      "model": "omlx/Qwen3.5-35B-A3B-8bit",
      "maxSteps": 30
    },
    "pai-pm": {
      "model": "omlx/Qwen3.5-35B-A3B-8bit",
      "maxSteps": 30
    }
  },
  "instructions": [
    "AGENTS.md",
    "pai/context/steering-rules.md",
    "pai/context/user/profile.md",
    "pai/context/da/identity.md"
  ]
}