{
  "$schema": "https://opencode.ai/config.json",
  "model": "omlx/gemma-4-26b-a4b-it-4bit",
  "small_model": "omlx/gemma-4-26b-a4b-it-4bit",
  "disabled_providers": ["opencode"],
  "snapshot": false,
  "provider": {
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX (local MLX)",
      "options": {
        "baseURL": "http://host.docker.internal:8000/v1",
        "apiKey": "{env:OMLX_API_KEY}"
      },
      "models": {
        "gemma-4-26b-a4b-it-4bit": {
          "name": "Gemma 4 26B A4B (MLX)",
          "limit": { "context": 131072, "output": 8192 }
        },
        "gemma-4-31b-it-4bit": {
          "name": "Gemma 4 31B (MLX)",
          "limit": { "context": 131072, "output": 8192 }
        },
        "gpt-oss-20b-MXFP4-Q8": {
          "name": "GPT-OSS 20B (MLX)",
          "limit": { "context": 131072, "output": 8192 }
        }
      }
    }
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "codesearch": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "question": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "ls*": "allow",
      "rm -rf*": "deny"
    },
    "edit": {
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*": "ask"
    }
  },
  "compaction": { "auto": true, "prune": true },
  "watcher": {
    "ignore": ["**/node_modules/**", "**/dist/**", "**/.git/**", "**/vendor/**", "**/*.log", "**/coverage/**"]
  },
  "agent": {
    "pai-architect": { "model": "omlx/gemma-4-31b-it-4bit" },
    "pai-engineer": { "model": "omlx/gemma-4-31b-it-4bit" },
    "pai-designer": { "model": "omlx/gemma-4-26b-a4b-it-4bit" },
    "pai-qa": { "model": "omlx/gemma-4-26b-a4b-it-4bit" },
    "pai-pentester": { "model": "omlx/gemma-4-26b-a4b-it-4bit" },
    "pai-artist": { "model": "omlx/gemma-4-26b-a4b-it-4bit" },
    "pai-researcher": { "model": "omlx/gemma-4-26b-a4b-it-4bit" },
    "pai-sre": { "model": "omlx/gemma-4-26b-a4b-it-4bit" },
    "pai-pm": { "model": "omlx/gemma-4-26b-a4b-it-4bit" }
  },
  "instructions": ["AGENTS.md"]
}
