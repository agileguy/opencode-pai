{
  "$schema": "https://opencode.ai/config.json",
  "model": "omlx/gemma-4-26b-a4b-it-4bit",
  "small_model": "omlx/gemma-4-26b-a4b-it-4bit",
  "disabled_providers": [
    "opencode"
  ],
  "snapshot": false,
  "provider": {
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX (local MLX)",
      "options": {
        "baseURL": "http://host.docker.internal:8000/v1",
        "apiKey": "{env:OMLX_API_KEY}"
      },
      "models": {
        "gemma-4-26b-a4b-it-4bit": {
          "name": "Gemma 4 26B A4B (MLX)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "gemma-4-31b-it-4bit": {
          "name": "Gemma 4 31B (MLX)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "gpt-oss-20b-MXFP4-Q8": {
          "name": "GPT-OSS 20B (MLX)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    }
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "codesearch": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "question": "allow",
    "write": "allow",
    "bash": {
      "*": "allow",
      "rm -rf /workspace/repos/*": "deny",
      "rm -rf /home/*": "deny"
    },
    "edit": {
      "*.env": "deny",
      "*.env.*": "deny",
      "*": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.git/**",
      "**/vendor/**",
      "**/*.log",
      "**/coverage/**"
    ]
  },
  "agent": {
    "pai-boss": {
      "model": "omlx/gemma-4-31b-it-4bit",
      "maxSteps": 50
    },
    "pai-architect": {
      "model": "omlx/gemma-4-31b-it-4bit",
      "maxSteps": 30
    },
    "pai-engineer": {
      "model": "omlx/gemma-4-31b-it-4bit",
      "maxSteps": 40
    },
    "pai-designer": {
      "model": "omlx/gemma-4-26b-a4b-it-4bit",
      "maxSteps": 30
    },
    "pai-qa": {
      "model": "omlx/gemma-4-26b-a4b-it-4bit",
      "maxSteps": 30
    },
    "pai-pentester": {
      "model": "omlx/gemma-4-26b-a4b-it-4bit",
      "maxSteps": 20
    },
    "pai-artist": {
      "model": "omlx/gemma-4-26b-a4b-it-4bit",
      "maxSteps": 20
    },
    "pai-researcher": {
      "model": "omlx/gemma-4-26b-a4b-it-4bit",
      "maxSteps": 25
    },
    "pai-sre": {
      "model": "omlx/gemma-4-26b-a4b-it-4bit",
      "maxSteps": 30
    },
    "pai-pm": {
      "model": "omlx/gemma-4-26b-a4b-it-4bit",
      "maxSteps": 30
    }
  },
  "instructions": [
    "AGENTS.md",
    "pai/context/steering-rules.md",
    "pai/context/user/profile.md",
    "pai/context/da/identity.md"
  ]
}